// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  createdAt       DateTime         @default(now())
  users           User[]
  companies       Company[]
  discovered      DiscoveredCompany[]
  sequences       Sequence[]
  campaigns       OutreachCampaign[]
  suppressionList SuppressionList[]
  settings        Json?            
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String
  role            String       @default("USER")
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
}

model Company {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  companyName     String
  domain          String?        @unique
  industry        String?
  city            String?
  country         String?
  companySize     String?        
  source          String?        
  website         String?
  linkedinUrl     String?
  score           Int            @default(0)
  description     String?
  hiringSignal    String?
  status          String         @default("IDENTIFIED") // IDENTIFIED, ENRICHED, READY
  createdAt       DateTime       @default(now())
  contacts        Contact[]
  pipelineEntries OutreachPipeline[]
  activityLogs    ActivityLog[]
}

model DiscoveredCompany {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  domain          String?
  website         String?
  industry        String?
  city            String?
  country         String?
  source          String?
  rawMetadata     Json?
  status          String         @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime       @default(now())

  @@unique([organizationId, domain])
}

model Contact {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  name            String
  role            String?        
  email           String         @unique
  phone           String?
  linkedinUrl     String?
  timezone        String?        @default("UTC")
  priorityScore   Int            @default(0) // Higher = more important
  isPrimary       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  pipelineEntries OutreachPipeline[]
  sequenceStates  LeadSequenceState[]
  emailJobs       EmailJob[]
  activityLogs    ActivityLog[]
}

model OutreachPipeline {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id])
  stage           String         @default("discovered") // discovered, contact identified, message sent, replied, demo scheduled, partner onboarded
  lastContacted   DateTime?
  nextFollowup    DateTime?
  status          String         @default("active") // active, paused, closed
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model OutreachCampaign {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  templates       MessageTemplate[]
  createdAt       DateTime       @default(now())
}

model MessageTemplate {
  id              String           @id @default(uuid())
  campaignId      String
  campaign        OutreachCampaign @relation(fields: [campaignId], references: [id])
  name            String
  subject         String
  body            String           // Supports {{company_name}}, {{contact_name}}, {{industry}}
  createdAt       DateTime         @default(now())
}

model ActivityLog {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  contactId       String?
  contact         Contact?     @relation(fields: [contactId], references: [id])
  action          String       
  details         String?
  timestamp       DateTime     @default(now())
}

model Sequence {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  status          String         @default("DRAFT") 
  createdAt       DateTime       @default(now())
  steps           SequenceStep[]
  leadStates      LeadSequenceState[]
}

model SequenceStep {
  id              String         @id @default(uuid())
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id])
  orderIndex      Int
  waitDays        Int            @default(0) 
  subjectTemplate String
  bodyTemplate    String
  emailJobs       EmailJob[]
}

model LeadSequenceState {
  id              String         @id @default(uuid())
  contactId       String
  contact         Contact        @relation(fields: [contactId], references: [id])
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id])
  currentStepId   String?        
  status          String         @default("ENROLLED") 
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([contactId, sequenceId])
}

model EmailJob {
  id              String         @id @default(uuid())
  organizationId  String
  contactId       String
  contact         Contact        @relation(fields: [contactId], references: [id])
  sequenceStepId  String
  sequenceStep    SequenceStep   @relation(fields: [sequenceStepId], references: [id])
  scheduledAt     DateTime       
  status          String         @default("QUEUED") 
  providerMessageId String?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  events          Event[]
}

model Event {
  id              String       @id @default(uuid())
  emailJobId      String
  emailJob        EmailJob     @relation(fields: [emailJobId], references: [id])
  type            String       
  timestamp       DateTime     @default(now())
  metadata        Json?
}

model SuppressionList {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  email           String
  reason          String       
  createdAt       DateTime     @default(now())
  
  @@unique([organizationId, email])
}
