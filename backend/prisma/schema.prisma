// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  createdAt       DateTime         @default(now())
  users           User[]
  companies       Company[]
  sequences       Sequence[]
  suppressionList SuppressionList[]
  settings        Json?            // For rate limits, default sender info
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String
  role            String       @default("USER")
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
}

model Company {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  domain          String?
  industry        String?
  city            String?
  country         String?
  sizeRange       String?        
  description     String?
  hiringSignal    String?
  score           Int            @default(0)
  source          String?        
  status          String         @default("IDENTIFIED") // IDENTIFIED, ENRICHED, READY
  createdAt       DateTime       @default(now())
  contacts        Lead[]
  activityLogs    ActivityLog[]
}

model Lead {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  contactName     String
  role            String?        
  email           String
  phone           String?
  linkedinUrl     String?
  timezone        String?        
  status          String         @default("ACTIVE") // ACTIVE, UNSUBSCRIBED, BOUNCED, REPLIED
  
  // Pipeline Tracking
  pipelineStage   String         @default("discovered") // discovered, contact identified, message sent, replied, demo scheduled, partner onboarded
  lastContacted   DateTime?
  nextFollowup    DateTime?
  notes           String?
  
  createdAt       DateTime       @default(now())
  sequenceStates  LeadSequenceState[]
  emailJobs       EmailJob[]
  activityLogs    ActivityLog[]
}

model ActivityLog {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  leadId          String?
  lead            Lead?        @relation(fields: [leadId], references: [id])
  action          String       // e.g. "Message Sent", "Status Updated", "Note Added"
  details         String?
  timestamp       DateTime     @default(now())
}

model Sequence {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  status          String         @default("DRAFT") 
  createdAt       DateTime       @default(now())
  steps           SequenceStep[]
  leadStates      LeadSequenceState[]
}

model SequenceStep {
  id              String         @id @default(uuid())
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id])
  orderIndex      Int
  waitDays        Int            @default(0) 
  subjectTemplate String
  bodyTemplate    String
  emailJobs       EmailJob[]
}

model LeadSequenceState {
  id              String         @id @default(uuid())
  leadId          String
  lead            Lead           @relation(fields: [leadId], references: [id])
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id])
  currentStepId   String?        
  status          String         @default("ENROLLED") 
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([leadId, sequenceId])
}

model EmailJob {
  id              String         @id @default(uuid())
  organizationId  String
  leadId          String
  lead            Lead           @relation(fields: [leadId], references: [id])
  sequenceStepId  String
  sequenceStep    SequenceStep   @relation(fields: [sequenceStepId], references: [id])
  scheduledAt     DateTime       
  status          String         @default("QUEUED") 
  providerMessageId String?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  events          Event[]
}

model Event {
  id              String       @id @default(uuid())
  emailJobId      String
  emailJob        EmailJob     @relation(fields: [emailJobId], references: [id])
  type            String       
  timestamp       DateTime     @default(now())
  metadata        Json?
}

model SuppressionList {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  email           String
  reason          String       
  createdAt       DateTime     @default(now())
  
  @@unique([organizationId, email])
}
