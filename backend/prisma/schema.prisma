// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  createdAt       DateTime         @default(now())
  users           User[]
  companies       Company[]
  sequences       Sequence[]
  suppressionList SuppressionList[]
  settings        Json?            // For rate limits, default sender info
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String
  role            String       @default("USER")
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
}

model Company {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  domain          String?
  industry        String?
  city            String?
  country         String?
  sizeRange       String?        // e.g. 10-300
  description     String?
  hiringSignal    String?
  score           Int            @default(0)
  source          String?        // LinkedIn, Startup directory, etc.
  status          String         @default("IDENTIFIED") // IDENTIFIED, ENRICHED, READY
  createdAt       DateTime       @default(now())
  leads           Lead[]
}

model Lead {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  contactName     String
  role            String?        // Founder, HR, Talent Acquisition
  email           String
  linkedinProfile String?
  timezone        String?        // IANA Timezone string (e.g., America/New_York)
  status          String         @default("ACTIVE") // ACTIVE, UNSUBSCRIBED, BOUNCED, REPLIED
  pipelineStatus  String         @default("IDENTIFIED") // IDENTIFIED, FOUND, CONTACTED, REPLIED, DEMO, ONBOARDED
  createdAt       DateTime       @default(now())
  sequenceStates  LeadSequenceState[]
  emailJobs       EmailJob[]
}

model Sequence {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  status          String         @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  createdAt       DateTime       @default(now())
  steps           SequenceStep[]
  leadStates      LeadSequenceState[]
}

model SequenceStep {
  id              String         @id @default(uuid())
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id])
  orderIndex      Int
  waitDays        Int            @default(0) // Days to wait AFTER the previous step
  subjectTemplate String
  bodyTemplate    String
  emailJobs       EmailJob[]
}

model LeadSequenceState {
  id              String         @id @default(uuid())
  leadId          String
  lead            Lead           @relation(fields: [leadId], references: [id])
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id])
  currentStepId   String?        // Which step is the lead currently on or just finished
  status          String         @default("ENROLLED") // ENROLLED, FINISHED, STOPPED_REPLY, PAUSED
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([leadId, sequenceId])
}

model EmailJob {
  id              String         @id @default(uuid())
  organizationId  String
  leadId          String
  lead            Lead           @relation(fields: [leadId], references: [id])
  sequenceStepId  String
  sequenceStep    SequenceStep   @relation(fields: [sequenceStepId], references: [id])
  scheduledAt     DateTime       // UTC timestamp for when this should be sent
  status          String         @default("QUEUED") // QUEUED, PROCESSING, SENT, FAILED, CANCELLED
  providerMessageId String?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  events          Event[]
}

model Event {
  id              String       @id @default(uuid())
  emailJobId      String
  emailJob        EmailJob     @relation(fields: [emailJobId], references: [id])
  type            String       // OPEN, REPLY, CLICK, BOUNCE
  timestamp       DateTime     @default(now())
  metadata        Json?
}

model SuppressionList {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  email           String
  reason          String       // UNSUBSCRIBE, BOUNCE, MANUAL
  createdAt       DateTime     @default(now())
  
  @@unique([organizationId, email])
}
